generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ================= ENUMS ================= */

enum UserStatus {
  active
  banned
  suspended
}

enum DriverStatus {
  pending
  approved
  rejected
  suspended
}

enum TripStatus {
  requested
  accepted
  started
  completed
  cancelled
}

enum PaymentStatus {
  pending
  success
  failed
  refunded
}

enum DiscountType {
  percent
  fixed
}

enum WalletTransactionType {
  credit
  debit
  commission
  refund
}

enum VoucherStatus {
  active
  inactive
}

enum DisputeStatus {
  open
  investigating
  resolved
}

enum TipStatus {
  success
  failed
  refunded
}

/* ================= ROLES ================= */

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/* ================= USERS ================= */

model User {
  id            String   @id @default(uuid())
  fullName      String?
  phone         String   @unique
  email         String?  @unique
  password      String

  roleId        Int
  role          Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  status        UserStatus @default(active)
  isVerified    Boolean    @default(false)
  lastLoginAt   DateTime?

  customer      Customer?
  driver        Driver?
  wallet        Wallet?

  messages      Message[]

  disputesCreated  Dispute[] @relation("CreatedBy")
  disputesResolved Dispute[] @relation("ResolvedBy")

  /* ================= FIX LỖI Ở ĐÂY ================= */

  driverDocumentsReviewed DriverDocument[]
  voucherUsages           VoucherUsage[]
  tipLogs                 TipLog[]

  /* ================================================ */

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/* ================= CUSTOMERS ================= */

model Customer {
  id        String @id @default(uuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName  String?
  avatarUrl String?

  vehicles  CustomerVehicle[]
  trips     Trip[]
  reviews   Review[]
  tips      TripTip[]

  createdAt DateTime @default(now())
}

/* ================= DRIVERS ================= */

model Driver {
  id            String @id @default(uuid())
  userId        String @unique
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName      String?
  avatarUrl     String?

  cccdNumber    String @unique
  licenseNumber String @unique
  licenseType   String?

  ratingAvg     Float?
  totalTrips    Int     @default(0)
  isOnline      Boolean @default(false)
  status        DriverStatus @default(pending)

  documents     DriverDocument[]
  trips         Trip[]
  reviews       Review[]
  tips          TripTip[]
  commissions   TripCommission[]

  createdAt     DateTime @default(now())
}

/* ================= DRIVER DOCUMENTS ================= */

model DriverDocument {
  id          String @id @default(uuid())

  driverId    String
  driver      Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  documentType String
  fileUrl      String
  status       String

  reviewedById String?
  reviewedBy   User? @relation(fields: [reviewedById], references: [id])

  reviewedAt   DateTime?
  uploadedAt   DateTime @default(now())
}

/* ================= CUSTOMER VEHICLES ================= */

model CustomerVehicle {
  id          String @id @default(uuid())

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  plateNumber String @unique
  brand       String?
  model       String?
  color       String?
  year        Int?
  vehicleType String?
  note        String?
  isDefault   Boolean @default(false)

  trips       Trip[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/* ================= TRIPS ================= */

model Trip {
  id            String @id @default(uuid())

  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])

  driverId      String?
  driver        Driver? @relation(fields: [driverId], references: [id])

  vehicleId     String?
  vehicle       CustomerVehicle? @relation(fields: [vehicleId], references: [id])

  pickupAddress  String
  pickupLat      Float
  pickupLng      Float

  dropoffAddress String
  dropoffLat     Float
  dropoffLng     Float

  distanceKm     Float?
  durationEstimateMin Int?

  priceEstimate  Float?
  finalPrice     Float?
  tipTotalAmount Float?

  status         TripStatus @default(requested)
  cancelBy       String?
  cancelReason   String?

  paymentStatus  PaymentStatus @default(pending)

  feeBreakdowns  TripFeeBreakdown[]
  commissions    TripCommission[]
  payments       Payment[]
  review         Review?
  tips           TripTip[]
  conversation   Conversation?

  disputes       Dispute[]
  voucherUsages  VoucherUsage[]

  createdAt      DateTime @default(now())
  acceptedAt     DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?

  @@index([customerId])
  @@index([driverId])
  @@index([status])
}

/* ================= TRIP FEES ================= */

model TripFeeBreakdown {
  id        String @id @default(uuid())

  tripId    String
  trip      Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  feeType   String
  amount    Float

  createdAt DateTime @default(now())
}

/* ================= COMMISSION ================= */

model CommissionPolicy {
  id            String @id @default(uuid())
  name          String
  ratePercent   Float
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean @default(true)

  commissions   TripCommission[]
}

model TripCommission {
  id                  String @id @default(uuid())

  tripId              String
  trip                Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  driverId            String
  driver              Driver @relation(fields: [driverId], references: [id])

  commissionPolicyId  String
  commissionPolicy    CommissionPolicy @relation(fields: [commissionPolicyId], references: [id])

  commissionAmount    Float

  createdAt           DateTime @default(now())
}

/* ================= PAYMENTS ================= */

model Payment {
  id            String @id @default(uuid())

  tripId        String
  trip          Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  method        String
  gatewayName   String?
  transactionId String?
  amount        Float
  currency      String @default("VND")

  status        PaymentStatus @default(pending)
  failureReason String?
  paidAt        DateTime?

  createdAt     DateTime @default(now())
}

/* ================= WALLET ================= */

model Wallet {
  id        String @id @default(uuid())

  userId    String @unique
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance   Float @default(0)

  transactions WalletTransaction[]

  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id           String @id @default(uuid())

  walletId     String
  wallet       Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type         WalletTransactionType
  referenceType String?
  referenceId   String?

  amount       Float
  description  String?

  createdAt    DateTime @default(now())
}

/* ================= VOUCHERS ================= */

model Voucher {
  id                  String @id @default(uuid())
  code                String @unique
  discountType        DiscountType
  discountValue       Float
  maxDiscountAmount   Float?
  minTripAmount       Float?
  usageLimitTotal     Int?
  usageLimitPerUser   Int?
  startDate           DateTime
  endDate             DateTime?
  isActive            Boolean @default(true)

  usages              VoucherUsage[]
}

model VoucherUsage {
  id            String @id @default(uuid())

  voucherId     String
  voucher       Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  userId        String
  user          User @relation(fields: [userId], references: [id])

  tripId        String
  trip          Trip @relation(fields: [tripId], references: [id])

  discountAmount Float
  usedAt        DateTime @default(now())
}

/* ================= CHAT ================= */

model Conversation {
  id        String @id @default(uuid())

  tripId    String @unique
  trip      Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  messages  Message[]

  createdAt DateTime @default(now())
}

model Message {
  id             String @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId       String
  sender         User @relation(fields: [senderId], references: [id])

  messageType    String
  content        String?
  fileUrl        String?
  isRead         Boolean @default(false)

  createdAt      DateTime @default(now())
}

/* ================= REVIEWS ================= */

model Review {
  id          String @id @default(uuid())

  tripId      String @unique
  trip        Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])

  driverId    String
  driver      Driver @relation(fields: [driverId], references: [id])

  rating      Int
  comment     String?

  createdAt   DateTime @default(now())
}

/* ================= DISPUTES ================= */

model Dispute {
  id          String @id @default(uuid())

  tripId      String
  trip        Trip @relation(fields: [tripId], references: [id])

  createdById String
  createdBy   User @relation("CreatedBy", fields: [createdById], references: [id])

  reason      String
  description String?

  status      DisputeStatus @default(open)

  resolvedById String?
  resolvedBy   User? @relation("ResolvedBy", fields: [resolvedById], references: [id])

  resolvedAt  DateTime?

  createdAt   DateTime @default(now())
}

/* ================= TIP ================= */

model TripTip {
  id          String @id @default(uuid())

  tripId      String
  trip        Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])

  driverId    String
  driver      Driver @relation(fields: [driverId], references: [id])

  amount      Float
  status      TipStatus @default(success)

  logs        TipLog[]

  createdAt   DateTime @default(now())
}

model TipLog {
  id          String @id @default(uuid())

  tipId       String
  tip         TripTip @relation(fields: [tipId], references: [id], onDelete: Cascade)

  performedBy String
  performer   User @relation(fields: [performedBy], references: [id])

  action      String

  createdAt   DateTime @default(now())
}