generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id                      Int              @id @default(autoincrement())
  fullName                String?
  phone                   String           @unique
  avatarUrl               String?
  email                   String?          @unique
  password                String
  roleId                  Int
  status                  UserStatus       @default(active)
  isVerified              Boolean          @default(false)
  lastLoginAt             DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  customer                Customer?
  disputesCreated         Dispute[]        @relation("CreatedBy")
  disputesResolved        Dispute[]        @relation("ResolvedBy")
  driver                  Driver?
  driverDocumentsReviewed DriverDocument[]
  messages                Message[]
  tipLogs                 TipLog[]
  role                    Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)
  voucherUsages           VoucherUsage[]
  wallet                  Wallet?
  notifications           Notification[]
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  content   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Customer {
  id             Int               @id @default(autoincrement())
  userId         Int               @unique
  fullName       String?
  avatarUrl      String?
  createdAt      DateTime          @default(now())
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles       CustomerVehicle[]
  reviews        Review[]
  savedAddresses SavedAddress[]
  trips          Trip[]
  tips           TripTip[]
}

model SavedAddress {
  id         Int      @id @default(autoincrement())
  customerId Int
  type       String
  name       String
  address    String
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Driver {
  id             Int              @id @default(autoincrement())
  userId         Int              @unique
  fullName       String?
  avatarUrl      String?
  cccdNumber     String           @unique
  licenseNumber  String           @unique
  licenseType    String?
  ratingAvg      Float?
  totalTrips     Int              @default(0)
isOnline       Boolean          @default(false)
  status         DriverStatus     @default(pending)
  suspendedUntil DateTime?
  reason         String?
  createdAt      DateTime         @default(now())
  currentLat     Float?
  currentLng     Float?
  isBusy         Boolean          @default(false)
  lastLocationAt DateTime?
  rankId         Int?
  DriverRank     DriverRank?      @relation(fields: [rankId], references: [id])
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents      DriverDocument[]
  reviews        Review[]
  trips          Trip[]
  commissions    TripCommission[]
  tips           TripTip[]
  locationHistory DriverLocationHistory[]
}

model DocumentType {
  id          Int              @id @default(autoincrement())
  name        String
  code        String           @unique
  description String?
  isRequired  Boolean          @default(true)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  documents   DriverDocument[]
}

model DriverDocument {
  id             Int          @id @default(autoincrement())
  driverId       Int
  documentTypeId Int
  fileUrl        String
  status         String
  reviewedById   Int?
  reviewedAt     DateTime?
  uploadedAt     DateTime     @default(now())
  documentType   DocumentType @relation(fields: [documentTypeId], references: [id])
  driver         Driver       @relation(fields: [driverId], references: [id], onDelete: Cascade)
  reviewedBy     User?        @relation(fields: [reviewedById], references: [id])
}

model CustomerVehicle {
  id          Int      @id @default(autoincrement())
  customerId  Int
  plateNumber String   @unique
  brand       String?
  model       String?
  color       String?
  year        Int?
  vehicleType String?
  note        String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  trips       Trip[]
}

model Trip {
  id                  Int                @id @default(autoincrement())
  customerId          Int
  driverId            Int?
  vehicleId           Int?
  pickupAddress       String
  pickupLat           Float
  pickupLng           Float
  dropoffAddress      String
  dropoffLat          Float
  dropoffLng          Float
  distanceKm          Float?
  durationEstimateMin Int?
  priceEstimate       Float?
  routePolyline       String?
  finalPrice          Float?
  tipTotalAmount      Float?
  status              TripStatus         @default(requested)
  paymentStatus       PaymentStatus      @default(pending)
  createdAt           DateTime           @default(now())
  conversation        Conversation?
  disputes            Dispute[]
  payments            Payment[]
  review              Review?
  customer            Customer           @relation(fields: [customerId], references: [id])
driver              Driver?            @relation(fields: [driverId], references: [id])
  vehicle             CustomerVehicle?   @relation(fields: [vehicleId], references: [id])
  commissions         TripCommission[]
  feeBreakdowns       TripFeeBreakdown[]
  tips                TripTip[]
  voucherUsages       VoucherUsage[]
  locationHistory     DriverLocationHistory[]

  @@index([customerId])
  @@index([driverId])
}

model TripFeeBreakdown {
  id        Int      @id @default(autoincrement())
  tripId    Int
  feeType   String
  amount    Float
  createdAt DateTime @default(now())
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model CommissionPolicy {
  id            Int              @id @default(autoincrement())
  name          String
  ratePercent   Float
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean          @default(true)
  commissions   TripCommission[]
}

model TripCommission {
  id                 Int              @id @default(autoincrement())
  tripId             Int
  driverId           Int
  commissionPolicyId Int
  commissionAmount   Float
  createdAt          DateTime         @default(now())
  commissionPolicy   CommissionPolicy @relation(fields: [commissionPolicyId], references: [id])
  driver             Driver           @relation(fields: [driverId], references: [id])
  trip               Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Payment {
  id            Int           @id @default(autoincrement())
  tripId        Int
  method        String
  gatewayName   String?
  transactionId String?
  amount        Float
  currency      String        @default("VND")
  status        PaymentStatus @default(pending)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  trip          Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Wallet {
  id           Int                 @id @default(autoincrement())
  userId       Int                 @unique
  balance      Float               @default(0)
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          Int                   @id @default(autoincrement())
  walletId             Int
  type                 WalletTransactionType
  amount               Float
  description          String?
  gatewayTransactionId String?               @unique
  reference            String?
  createdAt            DateTime              @default(now())
  wallet               Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Voucher {
  id            Int            @id @default(autoincrement())
  code          String         @unique
  discountType  DiscountType
  discountValue Float
  maxDiscount   Float?
  minOrderValue Float?
  usageLimit    Int?
  usedCount     Int            @default(0)
  target        String         @default("all")
  startDate     DateTime
  endDate       DateTime?
isActive      Boolean        @default(true)
  usages        VoucherUsage[]
}

model VoucherUsage {
  id             Int      @id @default(autoincrement())
  voucherId      Int
  userId         Int
  tripId         Int
  discountAmount Float
  usedAt         DateTime @default(now())
  trip           Trip     @relation(fields: [tripId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
  voucher        Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        Int       @id @default(autoincrement())
  tripId    Int       @unique
  createdAt DateTime  @default(now())
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  senderId       Int
  messageType    String
  content        String?
  fileUrl        String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])
}

model Review {
  id         Int      @id @default(autoincrement())
  tripId     Int      @unique
  customerId Int
  driverId   Int
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id])
  driver     Driver   @relation(fields: [driverId], references: [id])
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Dispute {
  id           Int           @id @default(autoincrement())
  tripId       Int
  createdById  Int
  reason       String
  description  String?
  status       DisputeStatus @default(open)
  resolvedById Int?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  createdBy    User          @relation("CreatedBy", fields: [createdById], references: [id])
  resolvedBy   User?         @relation("ResolvedBy", fields: [resolvedById], references: [id])
  trip         Trip          @relation(fields: [tripId], references: [id])
}

model TripTip {
  id         Int       @id @default(autoincrement())
  tripId     Int
  customerId Int
  driverId   Int
  amount     Float
  status     TipStatus @default(success)
  createdAt  DateTime  @default(now())
  logs       TipLog[]
  customer   Customer  @relation(fields: [customerId], references: [id])
  driver     Driver    @relation(fields: [driverId], references: [id])
  trip       Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model TipLog {
  id          Int      @id @default(autoincrement())
  tipId       Int
  performedBy Int
  action      String
  createdAt   DateTime @default(now())
  performer   User     @relation(fields: [performedBy], references: [id])
tip         TripTip  @relation(fields: [tipId], references: [id], onDelete: Cascade)
}

model PricingConfig {
  id                 Int      @id @default(autoincrement())
  name               String   @unique
  vehicleType        String?
  perKmPrice         Float    @default(12000)
  perMinPrice        Float    @default(500)
  nightMultiplier    Float    @default(1.3)
  rushHourMultiplier Float    @default(1.2)
  holidayMultiplier  Float    @default(1.0)
  badWeatherFee      Float    @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model DriverRank {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  code           String   @unique
  minTrips       Int      @default(0)
  driverRate     Float    @default(80)
  platformRate   Float    @default(20)
  acceptanceRate String   @default("92%")
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  Driver         Driver[]
}

model SystemConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

enum UserStatus {
  active
  banned
  suspended
}

enum DriverStatus {
  pending
  approved
  rejected
  suspended
}

enum TripStatus {
  requested
  accepted
  arrived
  started
  completed
  cancelled
}

enum PaymentStatus {
  pending
  success
  failed
  refunded
}

model DriverLocationHistory {
  id        Int      @id @default(autoincrement())
  driverId  Int
  tripId    Int?
  lat       Float
  lng       Float
  createdAt DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  trip   Trip?  @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([driverId, createdAt])
  @@index([tripId])
}

enum DiscountType {
  percent
  fixed
}

enum WalletTransactionType {
  credit
  debit
  commission
  refund
}

enum DisputeStatus {
  open
  investigating
  resolved
}

enum TipStatus {
  success
  failed
  refunded
}